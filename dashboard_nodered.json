  {
    "id": "tpl_mf",
    "type": "ui_template",
    "name": "Pertinencia",
    "group": "grp_fuzzy",
    "order": 1,
    "width": "6",
    "height": "5",
    "format": "<div style='font-family:sans-serif'>\n<b>Funcoes de Pertinencia - Erro (RPM)</b>\n<svg viewBox='0 0 520 160' style='width:100%;max-width:520px'>\n  <!-- Axes -->\n  <line x1='40' y1='130' x2='510' y2='130' stroke='#888'/>\n  <line x1='40' y1='20' x2='40' y2='130' stroke='#888'/>\n  <!-- Axis labels -->\n  <text x='40' y='148' font-size='10' text-anchor='middle'>-500</text>\n  <text x='87' y='148' font-size='10' text-anchor='middle'>-400</text>\n  <text x='181' y='148' font-size='10' text-anchor='middle'>-200</text>\n  <text x='275'    y='148' font-size='10' text-anchor='middle'>0</text>\n  <text x='369'  y='148' font-size='10' text-anchor='middle'>+200</text>\n  <text x='463'  y='148' font-size='10' text-anchor='middle'>+400</text>\n  <text x='510'  y='148' font-size='10' text-anchor='middle'>+500</text>\n  <!-- NG: trapEsq(-400,-200) -->\n  <polyline points='40,20 87,20 181,130' fill='none' stroke='#1f77b4' stroke-width='2'/>\n  <!-- NP: tri(-400,-200,0) -->\n  <polyline points='87,130 181,20 275,130' fill='none' stroke='#17becf' stroke-width='2'/>\n  <!-- Z: tri(-100,0,100) -->\n  <polyline points='228,130 275,20 322,130' fill='none' stroke='#2ca02c' stroke-width='2'/>\n  <!-- PP: tri(0,200,400) -->\n  <polyline points='275,130 369,20 463,130' fill='none' stroke='#ff7f0e' stroke-width='2'/>\n  <!-- PG: trapDir(200,400) -->\n  <polyline points='369,130 463,20 510,20' fill='none' stroke='#d62728' stroke-width='2'/>\n</svg>\n<div style='font-size:11px'>\n<span style='color:#1f77b4'>&#9632; NG</span>&nbsp;\n<span style='color:#17becf'>&#9632; NP</span>&nbsp;\n<span style='color:#2ca02c'>&#9632; Z</span>&nbsp;\n<span style='color:#ff7f0e'>&#9632; PP</span>&nbsp;\n<span style='color:#d62728'>&#9632; PG</span>\n</div></div>",
    "storeOutMessages": true,
    "fwdInMessages": true,
    "templateScope": "local",
    "x": 520,
    "y": 640,
    "z": "tab_c213",
    "wires": [
