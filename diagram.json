    { "type": "wokwi-buzzer", "id": "buz1", "top": 250, "left": 140, "attrs": {} }
  ],
  "connections": [
    [ "esp:TX0", "$serialMonitor:RX", "", [] ],
    [ "esp:RX0", "$serialMonitor:TX", "", [] ],

    [ "servo1:PWM", "esp:D18", "green", [] ],
    [ "servo1:V+",  "esp:5V",  "red",   [] ],
    [ "servo1:GND", "esp:GND.1","black",[] ],

    [ "esp:3V3", "lcd1:VCC", "red",    [] ],
    [ "esp:GND.2","lcd1:GND", "black",  [] ],
    [ "esp:D21", "lcd1:SDA", "blue",   [] ],
    [ "esp:D22", "lcd1:SCL", "purple", [] ],

    [ "esp:3V3", "pot1:VCC", "red",    [] ],
    [ "esp:GND.3","pot1:GND", "black",  [] ],
    [ "esp:D34", "pot1:SIG", "orange", [] ],

    [ "esp:D25", "led1:A", "green",  [] ],
    [ "esp:D26", "led2:A", "yellow", [] ],
    [ "esp:D27", "led3:A", "red",    [] ],
    [ "led1:C", "r1:1", "green", [] ], [ "r1:2", "esp:GND.1", "black", [] ],
    [ "led2:C", "r2:1", "green", [] ], [ "r2:2", "esp:GND.1", "black", [] ],
    [ "led3:C", "r3:1", "green", [] ], [ "r3:2", "esp:GND.1", "black", [] ],

    [ "esp:5V",  "ultra1:VCC", "red",   [] ],
    [ "esp:GND.3","ultra1:GND", "black", [] ],
    [ "esp:D5",  "ultra1:TRIG","green", [] ],
    [ "esp:D23", "ultra1:ECHO","blue",  [] ],

    [ "esp:D33", "btn1:1.l", "orange", [] ],
    [ "esp:GND.2","btn1:2.l", "black",  [] ],

    [ "esp:D32", "buz1:1", "magenta", [] ],
    [ "esp:GND.1","buz1:2", "black",   [] ]
