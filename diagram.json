    { "type": "wokwi-lcd1602", "id": "lcd1", "top": -120, "left": 200, "attrs": { "pins": "i2c", "address": "0x27" } },
    { "type": "wokwi-potentiometer", "id": "pot1", "top": 230, "left": -240, "attrs": { "label": "Carga (kg)" } },
    { "type": "wokwi-led", "id": "led1", "top": -160, "left": -120, "attrs": { "color": "green" } },
    { "type": "wokwi-led", "id": "led2", "top": -160, "left": -60,  "attrs": { "color": "yellow" } },
    { "type": "wokwi-led", "id": "led3", "top": -160, "left": 0,    "attrs": { "color": "red" } },
    { "type": "wokwi-resistor", "id": "r1", "top": -90, "left": -120, "rotate": 90, "attrs": { "value": "220" } },
    { "type": "wokwi-resistor", "id": "r2", "top": -90, "left": -60,  "rotate": 90, "attrs": { "value": "220" } },
    { "type": "wokwi-resistor", "id": "r3", "top": -90, "left": 0,    "rotate": 90, "attrs": { "value": "220" } },
